    "confirmed_at": "2026-03-23T13:08:58.258938"
  },
  {
    "id": 2,
    "title": "ціна плетіння бісмарк, скільки коштує бісмарк",
    "created_by": 189793675,
    "created": "2026-03-23T13:07:55.074503",
    "content": [
      {
        "text": "Бісмарк — 165 грн/г готового виробу із замком карабін. Замок-коробочка +600 грн доплата.",
        "timestamp": "2026-03-23T13:07:55.074506"
      }
    ],
    "media": [],
    "status": "confirmed",
    "migration_source": "insilver-v2",
